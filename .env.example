# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and must never be committed.

# --- PostgreSQL connection (option A: separate vars, no URL-encoding needed) ---
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=value_tree

# --- OR option B: a single connection string (encode special chars, e.g. @ = %40) ---
# DATABASE_URL=postgres://postgres:your_password@localhost:5432/value_tree

# --- Optional: enable real Claude AI insight (otherwise a heuristic is used) ---
# ANTHROPIC_API_KEY=sk-ant-...
